{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MyClaudia",
  "version": "0.1.205",
  "identifier": "com.myClaudia.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build && cd ../../.. && pnpm --filter @my-claudia/server run bundle",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MyClaudia",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../../server/bundle/": "server/"
    },
    "externalBin": [
      "binaries/node"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
