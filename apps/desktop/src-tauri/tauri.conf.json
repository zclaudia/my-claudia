{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MyClaudia",
  "version": "0.0.1",
  "identifier": "com.myClaudia.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build && cd ../../.. && pnpm --filter @my-claudia/server run bundle",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MyClaudia",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/node"
    ],
    "macOS": {
      "signingIdentity": "MyClaudia Signing",
      "hardenedRuntime": true,
      "minimumSystemVersion": "10.13"
    }
  },
  "plugins": {
    "shell": {
      "open": "((mailto:\\w+)|(tel:\\w+)|(https?://\\w+).+|/.*)"
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQwQUMxMTdBNUNDRDVCRDAKUldUUVc4MWNlaEdzUUw1VXI4WlpORGVySFc1QmJZN1E1U2tRNHVWRldMSG5JOGhCMXdpcEpIdTYK",
      "endpoints": [
        "https://github.com/zclaudia/my-claudia/releases/latest/download/latest.json"
      ]
    }
  }
}
