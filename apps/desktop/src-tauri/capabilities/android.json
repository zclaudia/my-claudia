{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "android",
  "description": "Capability for Android platform",
  "windows": ["main", "file-viewer-*"],
  "platforms": ["android"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:webview:allow-create-webview-window",
    "shell:allow-open",
    "fs:default",
    "fs:allow-download-read-recursive",
    "fs:allow-download-write-recursive",
    "shell:allow-kill",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "run-node",
          "cmd": "node",
          "args": true,
          "sidecar": false
        },
        {
          "name": "binaries/node",
          "sidecar": true,
          "args": true
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "run-node",
          "cmd": "node",
          "args": true,
          "sidecar": false
        },
        {
          "name": "binaries/node",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
