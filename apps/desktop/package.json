{
  "name": "@my-claudia/desktop",
  "version": "0.1.1220",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "clean": "rm -rf dist",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run",
    "test:unit": "vitest run --config=vitest.unit.config.ts",
    "test:ui": "vitest run --config=vitest.ui.config.ts",
    "test:all": "pnpm test:unit && pnpm test:ui",
    "test:parallel": "node scripts/test-parallel.mjs",
    "test:parallel:coverage": "node scripts/test-parallel.mjs --coverage",
    "test:parallel:fast": "node scripts/test-parallel-fast.mjs",
    "test:parallel:fast:coverage": "node scripts/test-parallel-fast.mjs --coverage",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:clear-cache": "rm -rf node_modules/.vitest-*"
  },
  "dependencies": {
    "@my-claudia/shared": "workspace:*",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-process": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@tauri-apps/plugin-updater": "^2.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.1",
    "ansi_up": "^6.0.6",
    "lucide-react": "^0.577.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^9.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-istanbul": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.0",
    "jsdom": "^27.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^4.0.18"
  }
}
