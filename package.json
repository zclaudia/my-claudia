{
  "name": "my-claudia",
  "version": "0.1.1220",
  "private": true,
  "description": "A cross-platform UI for Code CLI (Claude Code / Cursor / Codex)",
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "server:dev": "pnpm --filter @my-claudia/server run dev",
    "server:dev:isolated": "PORT=0 MY_CLAUDIA_DATA_DIR=$HOME/.my-claudia-dev pnpm --filter @my-claudia/server run dev",
    "gateway:dev": "pnpm --filter @my-claudia/gateway run dev",
    "desktop:dev": "pnpm --filter @my-claudia/desktop run dev",
    "build:macos": "bash scripts/build/macos.sh",
    "build:macos:install": "bash scripts/build/install-macos.sh",
    "release:macos": "bash scripts/release/macos.sh",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}\"",
    "test": "pnpm -r run test",
    "test:unit": "pnpm -r run test",
    "test:e2e": "vitest run --config e2e/vitest.config.e2e.ts",
    "test:e2e:ui": "vitest --config e2e/vitest.config.e2e.ts --ui",
    "test:e2e:workflows": "vitest run --config e2e/vitest.config.e2e.ts e2e/tests/user-workflows.spec.ts",
    "test:e2e:performance": "vitest run --config e2e/vitest.config.e2e.ts e2e/tests/performance.spec.ts",
    "test:e2e:local": "TEST_MODES=local vitest run --config e2e/vitest.config.e2e.ts",
    "test:e2e:remote": "TEST_MODES=remote vitest run --config e2e/vitest.config.e2e.ts",
    "test:e2e:gateway": "TEST_MODES=gateway vitest run --config e2e/vitest.config.e2e.ts",
    "test:e2e:modes": "vitest run --config e2e/vitest.config.e2e.ts e2e/tests/connection/",
    "test:e2e:shared": "vitest run --config e2e/vitest.config.e2e.ts e2e/tests/shared/",
    "test:e2e:playwright": "playwright test",
    "test:e2e:playwright:ui": "playwright test --ui",
    "test:e2e:playwright:debug": "playwright test --debug",
    "test:e2e:playwright:codegen": "playwright codegen http://localhost:1420",
    "test:e2e:playwright:report": "playwright show-report",
    "fixtures:generate": "node e2e/fixtures/performance-data/generate-fixtures.js",
    "test:desktop": "pnpm --filter @my-claudia/desktop run test",
    "test:server": "pnpm --filter @my-claudia/server run test",
    "postinstall": "node scripts/check-native-modules.mjs"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "@ai-sdk/openai": "^2.0.89",
    "@browserbasehq/stagehand": "^3.0.8",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.50.0",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.13.0",
    "openai": "^4.87.1",
    "playwright-core": "^1.58.1",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.4.2",
    "sharp": "^0.34.5",
    "typescript-eslint": "^8.18.2",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  }
}
